{
  "name": "homehelp",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev:website": "npm -w apps/website run dev",
    "dev:admin": "npm -w apps/admin run dev",
    "dev:api": "npm -w services/api run dev",
    "build:website": "npm -w apps/website run build",
    "build:admin": "npm -w apps/admin run build",
    "build:api": "npm -w services/api run build",
    "lint": "npm -w services/api run lint && npm -w apps/website run lint && npm -w apps/admin run lint",
    "typecheck": "npm -w services/api run typecheck",
    "secret-guard": "node scripts/secret-guard.mjs"
  }
}
