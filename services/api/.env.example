# Database
DATABASE_URL=""

# Upstash Redis (OTP/Cache)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# JWT
JWT_SECRET=""

# Razorpay (Payments)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Sentry (Error Tracking)
SENTRY_DSN=""

# Google Maps
GOOGLE_MAPS_API_KEY=""

# Resend (Transaction Email)
RESEND_API_KEY=""
EMAIL_FROM="HomeHelp <noreply@homehelp.ai>"

# UPI payment collection (fee-free, your own GPay/PhonePe UPI ID)
# Customers scan a per-booking QR that opens their UPI app prefilled with the amount.
# Payment is confirmed manually by an admin (migrate to Razorpay later if needed).
UPI_VPA=""
UPI_NAME="HomeHelp"

# Frontend base URL used in password-reset email links
FRONTEND_URL="https://homehelp-website.vercel.app"

# Firebase Admin SDK (service account key JSON as single string)
# Unused: do not set — firebase is fully removed.
FIREBASE_SERVICE_ACCOUNT_KEY=""

# Firebase Cloud Messaging (Push Notifications)
# Unused: replaced by web-push (VAPID) below.
FCM_SERVER_KEY=""

# VAPID keys for web push notifications (completely free, opt-in).
# Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is also set on the website Vercel project
# so the browser can subscribe. The private key stays server-side only.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:support@homehelp.ai"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""


# Server
PORT=3001
NODE_ENV=development

# CORS (comma-separated allowed origins for web + Expo dev)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,https://homehelp-admin.vercel.app,https://homehelp-website.vercel.app"
